DEBUG=False
SECRET_KEY=replace_me
DJANGO_SETTINGS_MODULE=config.settings

DB_NAME=fbr_pos_db
DB_USER=fbr_pos_user
DB_PASSWORD=replace_me
# For AWS RDS: set DB_HOST to your RDS endpoint.
# For local Postgres container: set DB_HOST=postgres and run compose with --profile local-db.
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_STORAGE_BUCKET_NAME=replace_me
AWS_S3_REGION_NAME=eu-north-1

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace_me
